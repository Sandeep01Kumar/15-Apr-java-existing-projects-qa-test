# ============================================================================
# Sample environment file for the Python (Flask) implementation of the
# Product CRUD API.
#
# Copy this file to `.env` and edit the values for your local environment:
#   cp .env.example .env
#
# The Python entry script `server.py` (and the test fixtures) read the
# `SQLALCHEMY_DATABASE_URI` environment variable at startup.
# ============================================================================

# ---------------------------------------------------------------------------
# Primary database URI — MySQL via PyMySQL.
#
# This is the production-equivalent setting. It mirrors the Java baseline,
# which uses mysql-connector-j (per pom.xml runtime dependency). The
# SQLAlchemy driver `mysql+pymysql://` is the Python pure-driver equivalent.
#
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
# ---------------------------------------------------------------------------
SQLALCHEMY_DATABASE_URI=mysql+pymysql://user:password@localhost:3306/product_db

# ---------------------------------------------------------------------------
# Local-development fallback — embedded SQLite (the Python analog of H2).
#
# Java declares H2 as a `<scope>runtime</scope>` optional dependency in
# pom.xml; SQLite plays the same role here for ergonomic local dev without
# a running MySQL server. Uncomment the line below (and comment out the
# MySQL line above) to switch.
# ---------------------------------------------------------------------------
# SQLALCHEMY_DATABASE_URI=sqlite:///./products.db

# ---------------------------------------------------------------------------
# In-memory SQLite — used by the pytest fixtures in tests/conftest.py.
# Operators normally do NOT need to set this manually; conftest.py overrides
# the URI to `sqlite:///:memory:` programmatically when running tests.
# ---------------------------------------------------------------------------
# SQLALCHEMY_DATABASE_URI=sqlite:///:memory:
